{
  "css.lint.unknownAtRules": "ignore",
  "css.validate": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "json.schemas": [
    {
      "fileMatch": [
        "package.json"
      ],
      "url": "https://json.schemastore.org/package.json"
    }
  ],
  "json.schemaDownload.enable": false
}
